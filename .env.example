# Copy to .env and fill in. Do NOT commit .env (it is gitignored).

# The client's Domo instance hostname (no https://)
DOMO_INSTANCE=yourinstance.domo.com

# Long-lived developer access token.
# Generate in Domo: Admin > Authentication > Access Tokens.
DOMO_ACCESS_TOKEN=

# Optional per-source instances (uncomment as needed):
# FIELDROUTES_INSTANCE=yourinstance.fieldroutes.com
